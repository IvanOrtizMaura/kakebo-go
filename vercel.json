{
  "buildCommand": "pnpm install && pnpm build && sed -i \"s|NG_APP_SUPABASE_URL_PLACEHOLDER|$NG_APP_SUPABASE_URL|g\" dist/kakebo-go/browser/*.js && sed -i \"s|NG_APP_SUPABASE_ANON_KEY_PLACEHOLDER|$NG_APP_SUPABASE_ANON_KEY|g\" dist/kakebo-go/browser/*.js",
  "devCommand": "ng serve",
  "installCommand": "pnpm install",
  "framework": "angular",
  "outputDirectory": "dist/kakebo-go/browser",
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
