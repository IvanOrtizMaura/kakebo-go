{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "dist/kakebo-go/browser",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "/api/chat",
        "function": {
          "functionId": "chat",
          "region": "europe-west1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
